{
  "name": "@axiscommunications/fluent-theme",
  "version": "10.9.0",
  "description": "Theme for Fluent UI v9",
  "homepage": "https://github.com/AxisCommunications/fluent-components#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/AxisCommunications/fluent-components.git",
    "directory": "theme"
  },
  "license": "MIT",
  "author": "Axis Communications AB",
  "type": "module",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "require": "./lib/cjs/index.js",
      "import": "./lib/index.js"
    }
  },
  "files": ["lib"],
  "scripts": {
    "build": "pnpm build:cjs && pnpm build:esm",
    "build:cjs": "tsc --module commonjs --outDir lib/cjs",
    "build:esm": "tsc",
    "check:unused-deps": "depcheck . --config=depcheck.yml",
    "lint": "tsc --noEmit && biome check",
    "tokens:build": "node tokens/build.js && pnpm tokens:build-ts-theme",
    "tokens:build-ts-theme": "node tokens/build-ts-theme.js",
    "tokens:runall": "pnpm tokens:transform && pnpm tokens:build",
    "tokens:transform": "node tokens/build-ts-to-json.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch"
  },
  "devDependencies": {
    "@types/node": "^20.11.18",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "style-dictionary": "^3.9.2",
    "token-transformer": "^0.0.33",
    "typescript": "^4.5.5",
    "@testing-library/jest-dom": "^6.6.3",
    "@vitest/coverage-c8": "^0.33.0",
    "@testing-library/react": "^14.2.1",
    "vitest": "^0.34.6",
    "jsdom": "^26.0.0"
  },
  "peerDependencies": {
    "@fluentui/react-components": "^9.58.2",
    "react": ">=16.8.0 <19.0.0",
    "react-dom": ">=16.8.0 <19.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  }
}
